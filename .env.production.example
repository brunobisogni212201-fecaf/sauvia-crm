# ========================================
# REDIS
# ========================================

# Opção A: ElastiCache (precisa criar)
# REDIS_URL=redis://sauvia-cache.xxxx.use1.cache.amazonaws.com:6379

# Opção B: Redis Cloud / Upstash (recomendado para dev)
REDIS_URL=redis://localhost:6379/0

# ========================================
# BACKEND - FastAPI (RENDER)
# ========================================

