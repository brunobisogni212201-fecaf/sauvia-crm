# ===========================
# Sauvia CRM - Environment Variables
# ===========================

# --- Database (GCP Cloud SQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/sauvia

# --- Clerk (Web/Mobile) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key

# --- NextAuth (Legacy Web) ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- GCP Identity Platform ---
GCP_PROJECT_ID=sauvia-crm
GCP_CLIENT_ID=your-client-id
GCP_CLIENT_SECRET=your-client-secret

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- Python Backend ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=generate-with-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Email (SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@sauvia.com.br

# --- WhatsApp (Evolute) ---
EVOLUTE_API_URL=http://localhost:8080
EVOLUTE_API_KEY=your-evolute-api-key
EVOLUTE_INSTANCE=your-instance-name

# ===========================
# Cloudflare + AWS Configuration
# ===========================

# --- Cloudflare ---
CF_ZONE_ID=0e75bef8e8dab2a320711e525e4c8a01
CF_ACCOUNT_ID=1261bfa2ba2fad9e536ab2868c6817d4
CF_API_TOKEN=your-cloudflare-api-token

# --- AWS ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=026544697783

# --- Production Domains ---
NEXT_PUBLIC_APP_URL=https://app.sauvia.qzz.io
NEXT_PUBLIC_API_URL=https://api.sauvia.qzz.io
