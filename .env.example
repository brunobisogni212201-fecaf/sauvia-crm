# ===========================
# Sauvia CRM - Environment Variables
# ===========================

# --- Database (GCP Cloud SQL) ---
DATABASE_URL=postgresql://user:password@localhost:5432/sauvia

# --- NextAuth (Web) ---
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# --- GCP Identity Platform ---
GCP_PROJECT_ID=sauvia-crm
GCP_CLIENT_ID=your-client-id
GCP_CLIENT_SECRET=your-client-secret

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# --- Backend API ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# --- Python Backend ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=generate-with-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Email (SendGrid) ---
SENDGRID_API_KEY=your-sendgrid-api-key
FROM_EMAIL=noreply@sauvia.com.br

# --- WhatsApp (Evolute) ---
EVOLUTE_API_URL=http://localhost:8080
EVOLUTE_API_KEY=your-evolute-api-key
EVOLUTE_INSTANCE=your-instance-name
